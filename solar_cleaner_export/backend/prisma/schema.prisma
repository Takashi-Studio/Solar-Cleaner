datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

model User {
  id                   Int          @id @default(autoincrement())
  name                 String
  username             String       @unique
  password_hash        String
  role                 String       @default("USER")
  theme_preference     String       @default("dark")
  email_alerts_enabled Boolean      @default(true)
  is_active            Boolean      @default(true)
  created_at           DateTime     @default(now())
  controllers          Controller[]

  @@map("users")
}

model Controller {
  id        String   @id
  user_id   Int?
  name      String
  status    String   @default("offline")
  last_seen DateTime @default(now())

  user  User?          @relation(fields: [user_id], references: [id], onDelete: SetNull)
  units CleaningUnit[]

  @@map("controllers")
}

model CleaningUnit {
  id            Int     @id @default(autoincrement())
  controller_id String
  port_number   Int // 1, 2, 3, or 4
  name          String // e.g., "اللوح الشرقي"
  state         String  @default("IDLE")
  water_level   Int     @default(0)
  speed         Int     @default(800)
  is_installed  Boolean @default(true)

  controller Controller    @relation(fields: [controller_id], references: [id], onDelete: Cascade)
  schedules  Schedule[]
  logs       CleaningLog[]

  @@map("cleaning_units")
}

model Schedule {
  id             Int      @id @default(autoincrement())
  unit_id        Int?
  schedule_type  String   @default("weekly") // "once" أو "weekly"
  cleaning_time  String // مثلاً "08:30"
  specific_date  String? // لتخزين تاريخ لمرة واحدة بصيغة "YYYY-MM-DD"
  days_of_week   String? // للأسبوعي المتكرر، مثل "1,3,5"
  interval_weeks Int      @default(1) // للتكرار كل X أسابيع (1، 2، 3، إلخ)
  is_active      Int      @default(1)
  created_at     DateTime @default(now())

  unit CleaningUnit? @relation(fields: [unit_id], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model CleaningLog {
  id                Int      @id @default(autoincrement())
  unit_id           Int?
  triggered_by      String
  status            String
  water_level_start Int?
  water_level_end   Int?
  duration_seconds  Int?
  created_at        DateTime @default(now())

  unit CleaningUnit? @relation(fields: [unit_id], references: [id], onDelete: Cascade)

  @@map("cleaning_logs")
}
