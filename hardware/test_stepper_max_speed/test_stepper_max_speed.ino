#include <Stepper.h>

// القيمة الرياضية القياسية لخطوات محرك 28BYJ-48
const int stepsPerRevolution = 2560;

// المحرك الأول (المنافذ: 8، 10، 9، 11) - الترتيب القياسي لـ Stepper.h
Stepper motor1(stepsPerRevolution, 8, 10, 9, 11);

// المحرك الثاني (المنافذ: 4، 6، 5، 7) - الترتيب القياسي لـ Stepper.h
Stepper motor2(stepsPerRevolution, 4, 5, 6, 7);

void setup() {
  // ضبط السرعة على 7 دورات في الدقيقة (RPM) - عزم دوران خارق وثبات تام
  motor1.setSpeed(7);
  motor2.setSpeed(7);
}

void loop() {
  // --- 1. اختبار التقدم (للأمام مسافة قصيرة = نصف دورة = 1024 خطوة) ---
  // قمنا بجعل إشارة المحرك الثاني سالبة (-1024) لتعوض التقابل الميكانيكي
  // وتسير العجلتان معاً لدفع العربة للأمام في خط مستقيم واحد!
  for (int i = 0; i < 5200; i++) {
    motor1.step(1);   // المحرك الأول خطوة للأمام
    motor2.step(-1);  // المحرك الثاني خطوة للخلف ميكانيكياً (للأمام حركياً)
  }
  
  delay(500); // الانتظار ثانية واحدة للاستقرار
  
  // --- 2. اختبار العودة (للخلف مسافة قصيرة = نصف دورة = 1024 خطوة) ---
  for (int i = 0; i < 5200; i++) {
    motor1.step(-1);  // المحرك الأول خطوة للخلف
    motor2.step(1);   // المحرك الثاني خطوة للأمام ميكانيكياً (للخلف حركياً)
  }
  
  delay(500); // الانتظار ثانية واحدة للاستقرار
}
